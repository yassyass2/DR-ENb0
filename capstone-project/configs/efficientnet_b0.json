{
  "experiment": {
    "name": "aptos-dr-classification",
    "run_name": "efficientnet-b0-baseline"
  },
  "data": {
    "preprocessed_dir": "data/preprocessed",
    "image_size": 224,
    "num_classes": 5
  },
  "model": {
    "name": "efficientnet_b0",
    "weights": "imagenet",
    "dropout": 0.3,
    "fine_tune_at": null
  },
  "training": {
    "batch_size": 16,
    "epochs": 10,
    "warmup_epochs": 3,
    "fine_tune_epochs": 15,
    "learning_rate": 0.0001,
    "fine_tune_learning_rate": 0.00001,
    "early_stopping_patience": 5,
    "augment": true,
    "seed": 42
  }
}
